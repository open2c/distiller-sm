rule scaling_pairs_library:
    input:
        pairs=f"{pairs_library_folder}/{{library}}.{{assembly_name}}.nodups.pairs.gz",
        chromsizes=get_library_chromsizes,
    output:
        scaling=f"{pairs_library_folder}/{{library}}.{{assembly_name}}.nodups.scaling.tsv",
    log:
        "logs/scaling_pairs_library/{library}.{assembly_name}.log",
    benchmark:
        "benchmarks/scaling_pairs_library/{library}.{assembly_name}.tsv"
    conda:
        "envs/pairtools_cooler.yml"
    threads: 4
    params:
        min_distance=config["scaling_pairs"].get("min_distance", 0),
        max_distance=lambda wildcards, input: (
            config["scaling_pairs"]["max_distance"]
            if config["scaling_pairs"].get("max_distance")
            else pd.read_table(input.chromsizes, header=None, names=["chrom", "size"])[
                "size"
            ].max()
        ),
        n_dist_bins_decade=config["scaling_pairs"].get("n_dist_bins_decade", 10),
        extra=config["scaling_pairs"].get("scaling_options", ""),
    shell:
        r"""
        pairtools scaling \
        --dist-range {params.min_distance} {params.max_distance} \
        --n-dist-bins-decade {params.n_dist_bins_decade} \
        {params.extra} \
        -o {output.scaling} \
        {input.pairs} \
        >{log[0]} 2>&1
        """


