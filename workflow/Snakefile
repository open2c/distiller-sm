    "view_genomes", "results/view_genomes"
)

assembly = config["input"]["genome"]["assembly_name"]
genome_path = config["input"]["genome"]["bwa_index_wildcard_path"].rstrip("*")
# custom_genome_folder = Path(config["genome"]["custom_genome_path"]).parent
chromsizes_path = config["input"]["genome"].get(
    "chrom_sizes_path", f"{genome_path}.chromsizes"
)

# Per-library genomic views for genome rearrangement
genomic_views = config.get("input", {}).get("genomic_views", {})
keep_view_genomes = config.get("input", {}).get("keep_view_genomes", False)


def get_library_assembly(library):
    """Return the assembly name for a library: '{assembly}.{view_stem}' if it has a
    genomic view, otherwise the base assembly name.
    The view stem is derived from the view file name (without extension)."""
    if library in genomic_views:
        view_stem = Path(genomic_views[library]).stem
        return f"{assembly}.{view_stem}"
    return assembly


def _maybe_temp(path):
    """Wrap path with temp() unless keep_view_genomes is True."""
    return path if keep_view_genomes else temp(path)


def _get_bwa_index_extensions(mapper):
    """Return the BWA index file extensions for the given mapper."""
    if mapper == "bwa-mem":
        return [".amb", ".ann", ".bwt", ".pac", ".sa"]
    elif mapper == "bwa-mem2":
        return [".0123", ".amb", ".ann", ".bwt.2bit.64", ".pac"]
    else:  # bwa-meme
        return [
            ".0123",
            ".amb",
            ".ann",
            ".pac",
            ".pos_packed",
            ".suffixarray_uint64",
            ".suffixarray_uint64_L0_PARAMETERS",
            ".suffixarray_uint64_L1_PARAMETERS",
            ".suffixarray_uint64_L2_PARAMETERS",
        ]


def get_library_genome_path(wildcards):
    """Return the genome FASTA path for the library in wildcards."""
    library = wildcards.library
    if library in genomic_views:
        return f"{view_genomes_folder}/{library}.{assembly}.fa"
    return genome_path


def get_library_chromsizes(wildcards):
    """Return the chromsizes path for the library in wildcards."""
    library = wildcards.library
    if library in genomic_views:
        return f"{view_genomes_folder}/{library}.{assembly}.chromsizes"
    return chromsizes_path


def get_library_bwa_idx(wildcards):
    """Return the BWA index files for the library in wildcards."""
    library = wildcards.library
    exts = _get_bwa_index_extensions(config["map"]["mapper"])
    if library in genomic_views:
        base = f"{view_genomes_folder}/{library}.{assembly}.fa"
        return [base + ext for ext in exts]
    return [genome_path + ext for ext in exts]


def get_library_chromap_idx(wildcards):
    """Return the chromap index file for the library in wildcards."""
    library = wildcards.library
    if library in genomic_views:
        return f"{view_genomes_folder}/{library}.{assembly}.fa.chromap.index"
    return genome_path + ".chromap.index"


LIBRARY_RUN_FASTQS = organize_fastqs(config)
runs = [list(LIBRARY_RUN_FASTQS[lib].keys()) for lib in LIBRARY_RUN_FASTQS.keys()]
runs = [item for sublist in runs for item in sublist]

resolutions_spec = config["bin"]["resolutions"]

if isinstance(resolutions_spec, list):
    min_resolution = min(config["bin"]["resolutions"])
    resolution_mode = "explicit"
    res_string = ",".join([str(res) for res in resolutions_spec])
elif isinstance(resolutions_spec, str):
    if resolutions_spec.lower() == "4dn":
        resolutions_spec = "1000,2000,5000n"
    if resolutions_spec.lower().endswith("b") or resolutions_spec.lower().endswith("n"):
        resolutions_mode = resolutions_spec[-1].lower()
        if len(resolutions_spec) == 1:
            raise ValueError(
                f"Invalid resolutions specification: please include at least one base resolution before the {resolutions_mode} suffix."
            )
        if not all(x.isdigit() for x in resolutions_spec[:-1].split(",")):
            raise ValueError(
                f"Invalid resolutions specification: all resolutions must be comma-separated integers before a one-letter suffix. Found: {resolutions_spec}."
            )
        resolutions = [int(x) for x in resolutions_spec[:-1].split(",")]
        min_resolution = min(resolutions)
        res_string = "B" if resolutions_mode == "b" else resolutions_spec
    else:
        raise ValueError(
            f"Invalid resolutions specification: {resolutions_spec}. For string specifications, use the following format: <base_resolution>[B|N], or '4DN' as an alias for '1000,2000,5000N'"
        )
else:
    raise ValueError(
        f"Invalid resolutions specification: {resolutions_spec}. Resolutions have to be a list or a string as specified in the documentation."
    )

