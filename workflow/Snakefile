rule merge_stats_libraries_into_groups:
    input:
        lambda wildcards: [
            f"{pairs_library_folder}/{library}.{get_library_assembly(library)}.dedup.stats"
            for library in config["input"]["library_groups"][wildcards.library_group]
        ],
    output:
        f"{stats_library_group_folder}/{{library_group}}.{{assembly_name}}.stats",
    log:
        "logs/merge_stats_libraries_into_groups/{library_group}.{assembly_name}.log",
    conda:
        "envs/pairtools_cooler.yml"
    shell:
        r"pairtools stats --merge {input} -o {output} >{log[0]} 2>&1"


rule multiqc:
    input:
        fastqc,
        [
            f"{pairs_library_folder}/{library}.{get_library_assembly(library)}.dedup.stats"
            for library in config["input"]["raw_reads_paths"].keys()
        ],
        [
            f"{stats_library_group_folder}/{group}.{get_group_assembly(group)}.stats"
            for group in config["input"]["library_groups"].keys()
        ]
        if "library_groups" in config["input"]
        else [],
    output:
        report=f"{multiqc_folder}/multiqc_report.html",
        dir=directory(multiqc_folder),
    log:
        "logs/multiqc.log",
    conda:
        "envs/multiqc.yml"
    params:
        input_dirs=lambda wildcards, input: list(set([Path(f).parent for f in input])),
        outdir=lambda wildcards, output: Path(output[0]).parent,
    shell:
        r"""multiqc -f --outdir {output.dir} -m pairtools -m fastqc \
        {params.input_dirs} \
        >{log} 2>&1"""


rule resgen_upload_library_group:
    input:
        mcool=f"{coolers_library_group_folder}/{{library_group}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.mcool",
    output:
        touch(
            f"{coolers_library_group_folder}/{{library_group}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.mcool_uploaded"
        ),
    log:
        f"logs/resgen_upload_library_group/{{library_group}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.log",
    conda:
        "envs/resgen_python.yml"
    params:
        user=config["resgen"]["user"],
        project=config["resgen"]["project"],
        assembly=assembly,
    shell:
        r"""resgen sync datasets '{params.user}' '{params.project}' {input.mcool} \
        --tag filetype:cooler --tag assembly:{params.assembly} --tag datatype:matrix \
        --force-update 'true' \
        >{log[0]} 2>&1
        """


use rule resgen_upload_library_group as resgen_upload_library with:
    input:
        mcool=f"{coolers_library_folder}/{{library}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.mcool",
    output:
        touch(
            f"{coolers_library_folder}/{{library}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.mcool_uploaded"
        ),
    log:
        f"logs/resgen_upload_library/{{library}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.log",
