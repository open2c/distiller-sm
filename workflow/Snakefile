# ---- Per-library genome rearrangement using viewtools ----
# If a library has a genomic view defined, rearrange the reference genome
# to create a custom FASTA for that library. The rearranged FASTA and its
# indexes are marked temp() to save disk space.

if genomic_views:

    rule rearrange_genome:
        input:
            genome=genome_path,
            view=lambda wildcards: genomic_views[wildcards.library],
        output:
            genome=_maybe_temp(f"{view_genomes_folder}/{{library}}.{assembly}.fa"),
        log:
            f"logs/rearrange_genome/{{library}}.{assembly}.log",
        conda:
            "envs/viewtools.yml"
        threads: 1
        shell:
            r"""
            viewtools rearrange-genome {input.genome} \
            --view {input.view} \
            --out {output.genome} \
            >{log} 2>&1
            """

    rule make_view_chromsizes:
        input:
            genome_fasta=f"{view_genomes_folder}/{{library}}.{assembly}.fa",
        output:
            chromsizes=f"{view_genomes_folder}/{{library}}.{assembly}.chromsizes",
        log:
            f"logs/make_view_chromsizes/{{library}}.{assembly}.log",
        conda:
            "envs/chromsize.yml"
        threads: 1
        shell:
            r"""
            chromsize --input {input.genome_fasta} --output {output.chromsizes} -t {threads} \
            >{log} 2>&1
            """

    if config["map"]["mapper"] == "chromap":

        rule chromap_index_view:
            input:
                genome=f"{view_genomes_folder}/{{library}}.{assembly}.fa",
            output:
                idx=_maybe_temp(
                    f"{view_genomes_folder}/{{library}}.{assembly}.fa.chromap.index"
                ),
            log:
                f"logs/chromap_index_view/{{library}}.{assembly}.log",
            conda:
                "envs/chromap.yml"
            shell:
                r"chromap -i -r {input.genome} -o {output.idx} >{log} 2>&1"

    else:

        view_idx_exts = _get_bwa_index_extensions(config["map"]["mapper"])

        rule bwaindex_view:
            input:
                genome=f"{view_genomes_folder}/{{library}}.{assembly}.fa",
            output:
                idx=_maybe_temp(
                    multiext(
                        f"{view_genomes_folder}/{{library}}.{assembly}.fa",
                        *view_idx_exts,
                    )
                ),
            log:
                f"logs/bwaindex_view/{{library}}.{assembly}.log",
            threads: 1
            params:
                bwa=config["map"]["mapper"],
            wrapper:
                "v4.6.0/bio/bwa-memx/index"


rule make_chromsizes:
    input:
        genome_fasta=config["input"]["genome"]["bwa_index_wildcard_path"].rstrip("*"),
    output:
        chromsizes=chromsizes_path,
    log:
        f"logs/make_chromsizes/{assembly}.log",
    conda:
        "envs/chromsize.yml"
    threads: 1
    shell:
        r"""
        chromsize --input {input.genome_fasta} --output {output.chromsizes} -t {threads} \
        >{log} 2>&1
        """


rule trim:
    input:
        sample=[
            f"{processed_fastqs_folder}/{{library}}/{{run}}/1.{{chunk_id}}.fastq.gz",
            f"{processed_fastqs_folder}/{{library}}/{{run}}/2.{{chunk_id}}.fastq.gz",
        ],
    output:
        # Would be better with a pipe, but it causes weird freezing of the pipeline
        trimmed=[
            temp(
                f"{processed_fastqs_folder}/{{library}}/{{run}}/1.{{chunk_id}}_trimmed.fastq.gz"
            ),
            temp(
                f"{processed_fastqs_folder}/{{library}}/{{run}}/2.{{chunk_id}}_trimmed.fastq.gz"
            ),
        ],
        json=f"{mapped_parsed_sorted_chunks_folder}/{{library}}/{{run}}/{{chunk_id}}.fastp.json",
        html=f"{mapped_parsed_sorted_chunks_folder}/{{library}}/{{run}}/{{chunk_id}}.fastp.html",
    log:
        "logs/fastp/{library}.{run}.{chunk_id}.log",
    params:
        extra=config["map"]["trim_options"],
    wrapper:
        "v4.6.0/bio/fastp"


if config["map"]["mapper"] == "chromap":

    rule chromap_index:
        input:
            genome=genome_path,
        output:
            idx=genome_path + ".chromap.index",
        log:
            f"logs/chromap_index/{assembly}.log",
        conda:
            "envs/chromap.yml"
        shell:
            r"chromap -i -r {input.genome} -o {output.idx} >{log} 2>&1"

    rule map_chunks_chromap:
        input:
            reads=lambda wildcards: (
                [
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/1.{{chunk_id}}_trimmed.fastq.gz",
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/2.{{chunk_id}}_trimmed.fastq.gz",
                ]
                if config["map"]["trim_options"]
                else [
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/1.{{chunk_id}}.fastq.gz",
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/2.{{chunk_id}}.fastq.gz",
                ]
            ),
            reference=get_library_genome_path,
            idx=get_library_chromap_idx,
        output:
            f"{mapped_parsed_sorted_chunks_folder}/{{library}}/{{run}}/{{chunk_id}}.{{assembly_name}}.pairs.gz",
        log:
            "logs/chromap/{library}.{run}.{chunk_id}.{assembly_name}.log",
        benchmark:
            "benchmarks/chromap/{library}.{run}.{chunk_id}.{assembly_name}.tsv"
        conda:
            "envs/chromap.yml"
        threads: 8
        params:
            extra=config["map"].get("mapping_options", ""),
        shell:
            # chromap doesn't output gzip files, so we need to pipe it to bgzip
            # For some reason it doesn't work with low memory mode in combination with
            # snakemake, so we can't use the hic preset... Might cause a problem with
            # memory for large dataset!
            # Hence I provide all arguments manually except for --low-mem
            r"""
            chromap -e 4 -q 1 --split-alignment --pairs -x {input.idx} \
            -r {input.reference} -t {threads} {params.extra} \
            -1 {input.reads[0]} -2 {input.reads[1]} \
            -o /dev/stdout 2>{log} | bgzip > {output}
            """

else:

    rule bwaindex:
        input:
            genome=genome_path,
        output:
            idx=idx,
        log:
            f"logs/bwa-memx_index/{assembly}.log",
        cache: True
        threads: 1  #Only affects bwa-meme
        params:
            bwa=config["map"]["mapper"],
        wrapper:
            "v4.6.0/bio/bwa-memx/index"

    # If we keep bams, simply store the output in the folder, otherwise pipe it to pairtools parse
    # Perhaps something with tee might be faster, had trouble getting it to work
    output_bam = f"{mapped_parsed_sorted_chunks_folder}/{{library}}/{{run}}/{{chunk_id}}.{{assembly_name}}.bam"
    if not config["parse"]["keep_unparsed_bams"]:
        output_bam = pipe(output_bam)

    rule map_chunks_bwa:
        input:
            reads=lambda wildcards: (
                [
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/1.{{chunk_id}}_trimmed.fastq.gz",
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/2.{{chunk_id}}_trimmed.fastq.gz",
                ]
                if config["map"]["trim_options"]
                else [
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/1.{{chunk_id}}.fastq.gz",
                    f"{processed_fastqs_folder}/{{library}}/{{run}}/2.{{chunk_id}}.fastq.gz",
                ]
            ),
            reference=get_library_genome_path,
            idx=get_library_bwa_idx,
        output:
            bam=output_bam,
        log:
            "logs/bwa_memx/{library}.{run}.{chunk_id}.{assembly_name}.log",
        benchmark:
            "benchmarks/bwa_memx/{library}.{run}.{chunk_id}.{assembly_name}.tsv"
        threads: 4
        params:
            bwa=config["map"]["mapper"],
            extra="-SP",
            sort="none",
            dedup="none",
        wrapper:
            "v2.2.1/bio/bwa-memx/mem"

    rule parse_sort_chunks:
        input:
            bam=f"{mapped_parsed_sorted_chunks_folder}/{{library}}/{{run}}/{{chunk_id}}.{{assembly_name}}.bam",
            chromsizes=get_library_chromsizes,
        output:
            f"{mapped_parsed_sorted_chunks_folder}/{{library}}/{{run}}/{{chunk_id}}.{{assembly_name}}.pairs.gz",
        log:
            "logs/parse_sort_chunks/{library}.{run}.{chunk_id}.{assembly_name}.log",
        benchmark:
            "benchmarks/parse_sort_chunks/{library}.{run}.{chunk_id}.{assembly_name}.tsv"
        conda:
            "envs/pairtools_cooler.yml"
        threads: 4
        params:
            # keep_bams_command=f"| tee >(samtools view -bS > {mapped_parsed_sorted_chunks_folder}/{{library}}/{{run}}/{{chunk_id}}.{assembly}.bam)"
            # if config["parse"]["keep_unparsed_bams"]
            # else "",
            dropsam_flag=(
                "" if config["parse"].get("make_pairsam", False) else "--drop-sam"
            ),
            dropreadid_flag=(
                "--drop-readid" if config["parse"].get("drop_readid", False) else ""
            ),
            dropseq_flag="--drop-seq" if config["parse"].get("drop_seq", True) else "",
            parsing_options=config["parse"].get("parsing_options", ""),
        shell:
            r"""
            pairtools parse {params.dropsam_flag} {params.dropreadid_flag} {params.dropseq_flag} \
            {params.parsing_options} \
            -c {input.chromsizes} {input.bam} \
            | pairtools sort --nproc {threads} -o {output} \
            >{log[0]} 2>&1
            """


# Find out the chunk ids for each library and run - since we don't know them beforehand
def get_pair_chunks(wildcards):
    checkpoint_output = checkpoints.chunk_fastq.get(**wildcards).output
    chunk_ids = glob_wildcards(
        f"{processed_fastqs_folder}/{wildcards.library}/{wildcards.run}/2.{{chunk_id}}.fastq.gz",
    ).chunk_id
    lib_asm = get_library_assembly(wildcards.library)
    paths = expand(
        f"{mapped_parsed_sorted_chunks_folder}/{wildcards.library}/{wildcards.run}/{{chunk_id}}.{lib_asm}.pairs.gz",
        chunk_id=chunk_ids,
    )
    return paths


rule merge_runs:
    input:
        get_pair_chunks,
    output:
        f"{pairs_runs_folder}/{{library}}/{{run}}.{{assembly_name}}.pairs.gz",
    log:
        "logs/merge_runs/{library}.{run}.{assembly_name}.log",
    benchmark:
        "benchmarks/merge_runs/{library}.{run}.{assembly_name}.tsv"
    conda:
        "envs/pairtools_cooler.yml"
    threads: 4
    params:
        command=lambda wildcards, input, threads, output: (
            f"pairtools merge {input} --nproc {threads} -o {output}"
            if len(input) > 1
            else f"ln -sr {input} {output}"
        ),
    shell:
        r"""{params.command} \
        >{log[0]} 2>&1
        """


if config["parse"]["make_pairsam"]:
    bytile_arg = (
        "--keep-parent-id --output-bytile-stats {output[7]}"
        if config["dedup"].get("save_by_tile_dups", False)
        else ""
    )
    dedup_command = """pairtools dedup {params.dedup_options} \
        --max-mismatch {params.max_mismatch_bp} \
        --mark-dups \
        --output \
            >( pairtools split \
                --output-pairs {output[0]} \
                --output-sam {output[1]} \
             ) \
        --output-unmapped \
            >( pairtools split \
                --output-pairs {output[2]} \
                --output-sam {output[3]} \
             ) \
        --output-dups \
            >( pairtools split \
                --output-pairs {output[4]} \
                --output-sam {output[5]} \
             ) \
        --output-stats {output[6]} \
        """ + bytile_arg + " && pairix {output[0]}"
    merge_output = multiext(
        f"{pairs_library_folder}/{{library}}.{{assembly_name}}",
        ".nodups.pairs.gz",
        ".nodups.bam",
        ".unmapped.pairs.gz",
        ".unmapped.bam",
        ".dups.pairs.gz",
        ".dups.bam",
        ".dedup.stats",
        ".nodups.pairs.gz.px2",
    )
else:
    bytile_arg = (
        "--keep-parent-id --output-bytile-stats {output[5]}"
        if config["dedup"].get("save_by_tile_dups", False)
        else ""
    )
    dedup_command = """pairtools dedup {params.dedup_options} \
        --max-mismatch {params.max_mismatch_bp} \
        --mark-dups \
        --output {output[0]} \
        --output-unmapped {output[1]} \
        --output-dups {output[2]} \
        --output-stats {output[3]} \
        """ + bytile_arg + " >{log[0]} 2>&1 && pairix {output[0]}"
    merge_output = multiext(
        f"{pairs_library_folder}/{{library}}.{{assembly_name}}",
        ".nodups.pairs.gz",
        ".unmapped.pairs.gz",
        ".dups.pairs.gz",
        ".dedup.stats",
        ".nodups.pairs.gz.px2",
    )
if config["dedup"].get("save_by_tile_dups", False):
    merge_output += [
        f"{pairs_library_folder}/{{library}}.{{assembly_name}}.by_tile_dups.txt"
    ]


rule merge_dedup:
    input:
        pairs=lambda wildcards: expand(
            f"{pairs_runs_folder}/{wildcards.library}/{{run}}.{wildcards.assembly_name}.pairs.gz",
            run=list(LIBRARY_RUN_FASTQS[wildcards.library].keys()),
        ),
    output:
        merge_output,
    log:
        "logs/merge_dedup/{library}.{assembly_name}.log",
    benchmark:
        "benchmarks/merge_dedup/{library}.{assembly_name}.tsv"
    conda:
        "envs/pairtools_cooler.yml"
    threads: 4
    params:
        dedup_options=lambda wildcards: config["dedup"].get("dedup_options", ""),
        max_mismatch_bp=config["dedup"]["max_mismatch_bp"],
        merge_command=lambda wildcards, input, threads: (
            f"pairtools merge {input} --nproc {threads} --keep-first-header | "
            if len(input) > 1
            else f"bgzip -dc -@ {threads-1} {input} | "
        ),
        phase_command=lambda wildcards, threads: (
            f'pairtools phase --tag-mode {config["phase"]["tag_mode"]} --phase-suffixes {" ".join(config["phase"]["suffixes"])} | pairtools sort --nproc {threads-1} | '
            if config.get("phase", {}).get("do_phase", False)
            else ""
        ),
    shell:
        (
            r"{params.merge_command}"
            + r"{params.phase_command}"
            + dedup_command
            + " >{log[0]} 2>&1"
        )


rule bin_pairs_library:
    input:
        pairs=f"{pairs_library_folder}/{{library}}.{{assembly_name}}.nodups.pairs.gz",
        chromsizes=get_library_chromsizes,
    output:
        cool=f"{coolers_library_folder}/{{library}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.cool",
    log:
        "logs/bin_pairs_library/{library}.{assembly_name}.{filter_name}.{min_resolution}.log",
    benchmark:
        "benchmarks/bin_pairs_library/{library}.{assembly_name}.{filter_name}.{min_resolution}.tsv"
    conda:
        "envs/pairtools_cooler.yml"
    threads: 4
    params:
        filter_command=lambda wildcards: (
            f'| pairtools select "{config["bin"]["filters"][wildcards.filter_name]}"'
            if config["bin"]["filters"][wildcards.filter_name]
            else ""
        ),
        assembly=assembly,
        bgzip_threads=lambda wildcards, threads: max(1, (threads - 1)),
    shell:
        r"""
        bgzip -dc -@ {params.bgzip_threads} {input.pairs} {params.filter_command} | cooler cload pairs -c1 2 -p1 3 -c2 4 -p2 5 \
        --assembly {params.assembly} \
        {input.chromsizes}:{wildcards.min_resolution} - {output.cool} >{log[0]} 2>&1
        """


rule zoom_library:
    input:
        cool=f"{coolers_library_folder}/{{library}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.cool",
    output:
        mcool=f"{coolers_library_folder}/{{library}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.mcool",
    log:
        "logs/zoom_library/{library}.{assembly_name}.{filter_name}.{min_resolution}.log",
    benchmark:
        "benchmarks/zoom_library/{library}.{assembly_name}.{filter_name}.{min_resolution}.tsv"
    conda:
        "envs/pairtools_cooler.yml"
    threads: 8
    params:
        balance_args=lambda wildcards, threads: (
            f"--balance --balance-args '{config['bin'].get('balance_options', '')} --nproc {threads}'"
            if config["bin"]["balance"]
            else ""
        ),
    shell:
        r"""
        cooler zoomify \
        --nproc {threads} \
        --out {output.mcool} \
        --resolutions {res_string} \
        {params.balance_args} \
        {input.cool} \
        >{log[0]} 2>&1
        """


rule merge_zoom_library_group_coolers:
    input:
        lambda wildcards: expand(
            f"{coolers_library_folder}/{{library}}.{wildcards.assembly_name}.{wildcards.filter_name}.{wildcards.min_resolution}.cool",
            library=config["input"]["library_groups"][wildcards.library_group],
        ),
    output:
        cool=f"{coolers_library_group_folder}/{{library_group}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.cool",
        mcool=f"{coolers_library_group_folder}/{{library_group}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.mcool",
    log:
        "logs/merge_zoom_library_group_coolers/{library_group}.{assembly_name}.{filter_name}.{min_resolution}.log",
    benchmark:
        "benchmarks/merge_zoom_library_group_coolers/{library_group}.{assembly_name}.{filter_name}.{min_resolution}.tsv"
    conda:
        "envs/pairtools_cooler.yml"
    threads: 8
    params:
        balance_args=lambda wildcards, threads: (
            f"--balance --balance-args '{config['bin'].get('balance_options', '')} --nproc {threads}'"
            if config["bin"]["balance"]
            else ""
        ),
    shell:
        r"""
        cooler merge {output.cool} {input} >{log[0]} 2>&1

        cooler zoomify \
        --nproc {threads} \
        --out {output.mcool} \
        --resolutions {res_string} \
        {params.balance_args} \
        {output.cool} \
        >{log[0]} 2>&1
        """


rule mcool2hic_group:
    input:
        mcool=f"{coolers_library_group_folder}/{{library_group}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.mcool",
    output:
        hic=f"{coolers_library_group_folder}/{{library_group}}.{{assembly_name}}.{{filter_name}}.{{min_resolution}}.hic",
    log:
        "logs/mcool2hic/{library_group}.{assembly_name}.{filter_name}.{min_resolution}.log",
    benchmark:
        "benchmarks/mcool2hic/{library_group}.{assembly_name}.{filter_name}.{min_resolution}.tsv"
    conda:
        "envs/hictk.yml"
    threads: 8
    params:
        tmpdir=coolers_library_group_folder,
    shell:
        r"""
        hictk convert --threads {threads} --tmpdir {params.tmpdir} \
        {input.mcool} {output.hic} >{log} 2>&1
        """


use rule mcool2hic_group as mcool2hic_library with:
